{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/argus-obsidian/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/public" }
    },
    {
      "src": "artifacts/api-server/src/app.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "artifacts/api-server/src/app.ts"
    },
    {
      "source": "/(.*)",
      "destination": "artifacts/argus-obsidian/$1"
    }
  ]
}
